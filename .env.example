# Application
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-strong-secret-key-at-least-32-chars
DEBUG=false

# CORS — comma-separated list of allowed frontend origins
# Local: http://localhost:3000
# Railway: https://your-frontend.railway.app
ALLOWED_ORIGINS=http://localhost:3000

# PostgreSQL (local Docker Compose)
POSTGRES_PASSWORD=changeme

# Railway / PaaS — set this instead of individual POSTGRES_* vars
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Cloudinary — get from https://cloudinary.com/console (free tier, 25 GB)
# Format: cloudinary://api_key:api_secret@cloud_name
# Leave empty to use local disk (dev only — not persistent on Render free tier)
CLOUDINARY_URL=cloudinary://...

# Stripe — get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
